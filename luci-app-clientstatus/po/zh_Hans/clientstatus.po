msgid "Client Management"
msgstr "客户端管理"

msgid "Status"
msgstr "状态"

msgid "Settings"
msgstr "设置"

msgid "Client Management Settings"
msgstr "客户端管理设置"

msgid "Configure the LAN client status monitor. Changes take effect after saving and restarting the service.<br />"
msgstr "配置局域网客户端状态监控。更改需保存并重启服务后生效。<br />"

msgid "Note: Restart the service if the page does not display correctly after changing network settings."
msgstr "注意：如果设置网络后显示不正常，请重启服务。"

msgid "General Settings"
msgstr "基本设置"

msgid "Enable"
msgstr "启用"

msgid "Enable or disable the client status monitoring service."
msgstr "启用或禁用客户端状态监控服务。"

msgid "Output File"
msgstr "输出文件"

msgid "Refresh Interval (seconds)"
msgstr "刷新间隔（秒）"

msgid "How often to scan and ping all clients. Default: 30 seconds."
msgstr "扫描并 ping 所有客户端的频率。默认：30秒。"

msgid "LAN Interface"
msgstr "局域网接口"

msgid "Network interface to scan for clients. Usually br-lan."
msgstr "扫描客户端的网络接口。通常为br-lan。"

msgid "Total Devices"
msgstr "设备总数"

