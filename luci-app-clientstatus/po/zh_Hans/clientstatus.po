msgid "Client Management"
msgstr "客户端管理"

msgid "Status"
msgstr "状态"

msgid "Settings"
msgstr "设置"

msgid "Client Management Settings"
msgstr "客户端管理设置"

msgid "Note: Restart the service if the page does not display correctly after changing network settings."
msgstr "如果设置网络后显示不正常，请重启服务。"

msgid "General Settings"
msgstr "基本设置"

msgid "Enable"
msgstr "启用"

msgid "Enable or disable the client status monitoring service."
msgstr "启用或禁用客户端状态监控服务。"

msgid "Refresh Interval (seconds)"
msgstr "刷新间隔（秒）"

msgid "How often to scan all clients. Default: 30 seconds."
msgstr "扫描客户端的频率。默认：30秒。"

msgid "LAN Interface"
msgstr "局域网接口"

msgid "Network interface to scan for clients. Usually br-lan."
msgstr "扫描客户端的网络接口。通常为br-lan。"

msgid "Total Devices"
msgstr "设备总数"

msgid "Online"
msgstr "在线"

msgid "Offline"
msgstr "离线"

msgid "Allowed"
msgstr "允许联网"

msgid "Blocked"
msgstr "禁止联网"

msgid "Ethernet"
msgstr "有线"

msgid "Search hostname, IP, MAC..."
msgstr "搜索主机名、IP、MAC……"

msgid "Filter:"
msgstr "筛选："

msgid "All NCS"
msgstr "在线状态"

msgid "All ACL"
msgstr "联网控制"

msgid "All NCT"
msgstr "连接类型"

msgid "Auto refresh"
msgstr "自动刷新"

msgid "Refresh"
msgstr "刷新"

msgid "Hostname"
msgstr "主机名"

msgid "MAC"
msgstr "MAC地址"

msgid "IP"
msgstr "IP地址"

msgid "Duration"
msgstr "持续时间"

msgid "NCT"
msgstr "连接类型"

msgid "ACL"
msgstr "联网控制"

msgid "SPEED"
msgstr "实时网速"

msgid "Click to toggle"
msgstr "点击进行修改"

msgid "Client data cleared"
msgstr "客户端数据已清除"

msgid "No clients found. Waiting..."
msgstr "未发现客户端"

msgid "Enable Speed Limit"
msgstr "启用限速功能"

msgid "Enable speed limit functionality for clients."
msgstr "启用客户端限速功能。"

msgid "Enable Traffic Statistics"
msgstr "启用流量统计"

msgid "Enable traffic statistics collection."
msgstr "启用流量统计收集功能。"

msgid "Traffic Data Retention (days)"
msgstr "流量数据保留天数"

msgid "How many days to keep traffic data. Default: 30 days."
msgstr "流量数据保留多少天。默认：30天。"

msgid "Speed Limit"
msgstr "限速"

msgid "Total Traffic"
msgstr "总流量"

msgid "Unlimited"
msgstr "不限速"

msgid "Click to set speed limit"
msgstr "点击设置限速"

msgid "Enter download limit (KB/s, 0 for unlimited):"
msgstr "输入下载限速（KB/s，0表示不限速）："

msgid "Enter upload limit (KB/s, 0 for unlimited):"
msgstr "输入上传限速（KB/s，0表示不限速）："

msgid "Speed limit set"
msgstr "限速已设置"

msgid "Are you sure you want to reset all traffic statistics?"
msgstr "确定要重置所有流量统计吗？"

msgid "Traffic statistics reset"
msgstr "流量统计已重置"

msgid "Reset Traffic"
msgstr "重置流量统计"

msgid "limited"
msgstr "已限速"

msgid "unlimited"
msgstr "未限速"
